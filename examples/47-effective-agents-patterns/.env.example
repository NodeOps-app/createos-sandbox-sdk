# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com
CREATEOS_SANDBOX_API_KEY=your-createos-sandbox-api-key

# OpenAI-compatible LLM proxy credentials (bridged into the sandbox).
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_URL=https://your-llm-proxy.example.com/v1
OPENAI_MODEL=your-model-name
