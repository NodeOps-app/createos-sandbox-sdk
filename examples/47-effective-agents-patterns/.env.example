# FC_BASE_URL (required) — your fc-spawn control-plane URL.
FC_BASE_URL=https://fc-spawn.example.com
FC_API_KEY=your-fc-spawn-api-key

# OpenAI-compatible LLM proxy credentials (bridged into the sandbox).
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_URL=https://your-llm-proxy.example.com/v1
OPENAI_MODEL=your-model-name
