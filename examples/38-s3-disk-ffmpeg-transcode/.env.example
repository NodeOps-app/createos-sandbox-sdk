# ── createos-sandbox control plane ──────────────────────────────────────────────────────
# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com

# ── S3-compatible bucket ──────────────────────────────────────────────────
# Registered as a createos-sandbox disk AND used locally (Bun.S3Client) to seed/list/verify.
# The bucket must be reachable from BOTH this machine and the createos-sandbox agent.
# Works with AWS S3, Cloudflare R2, MinIO, etc.
S3_BUCKET=my-media-bucket
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY=AKIAxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to 1 for MinIO / path-style endpoints. Leave unset/0 for AWS & R2.
# S3_USE_PATH_STYLE=1

# ── pipeline tuning (all optional) ────────────────────────────────────────
# INPUT_PREFIX=input/         # where videos are watched
# OUTPUT_PREFIX=output/       # where extracted audio is written
# POLL_INTERVAL_S=5           # seconds between poll cycles
# MAX_CYCLES=12               # stop after this many cycles
# CLEANUP_MODE=destroy        # destroy | pause the sandbox after each video
