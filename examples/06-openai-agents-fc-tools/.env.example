# Standard fc-sandbox-sdk inputs.
FC_BASE_URL=https://fc-spawn.bhautik.in
FC_API_KEY=fc_your_api_key_here

# Optional OpenAI Agents SDK model inputs.
# If OPENAI_API_KEY is omitted, the example uses a deterministic local model
# through the Agents SDK runner so the FC tool path remains runnable.
# OPENAI_API_KEY=sk_your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Optional: use an OpenAI-compatible endpoint with an API key.
# OPENAI_API_URL=https://your-openai-compatible-endpoint/v1
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# OPENAI_USE_CHAT_COMPLETIONS=true
