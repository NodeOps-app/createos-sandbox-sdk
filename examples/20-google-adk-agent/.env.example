# FC control plane
CREATEOS_SANDBOX_API_KEY=fc_...
# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com

# LLM backing ADK, reached through LiteLLM over an OpenAI-compatible proxy.
OPENAI_API_URL=https://your-openai-compatible-proxy/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
