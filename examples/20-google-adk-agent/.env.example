# FC control plane
FC_API_KEY=fc_...
# Base URL for the control plane. Defaults to the production control plane;
# set FC_BASE_URL only to override.
FC_BASE_URL=https://fc-spawn.bhautik.in

# LLM backing ADK, reached through LiteLLM over an OpenAI-compatible proxy.
OPENAI_API_URL=https://your-openai-compatible-proxy/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
