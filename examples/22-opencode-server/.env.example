# FC sandbox control plane
FCSPAWN_URL=https://your-fc-spawn-host
FC_API_KEY=your-fc-api-key
FCSPAWN_GATEWAY=https://your-fc-spawn-gateway

# Anthropic (used to configure opencode's LLM provider inside the sandbox)
ANTHROPIC_AUTH_TOKEN=your-anthropic-api-key-or-proxy-token
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5
