# createos-sandbox control plane
CREATEOS_SANDBOX_BASE_URL=https://your-createos-sandbox-host
CREATEOS_SANDBOX_API_KEY=your-createos-sandbox-api-key

# Anthropic (used to configure opencode's LLM provider inside the sandbox)
ANTHROPIC_AUTH_TOKEN=your-anthropic-api-key-or-proxy-token
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5
