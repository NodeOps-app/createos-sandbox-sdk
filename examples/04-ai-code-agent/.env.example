# Required: FC Sandbox API key
CREATEOS_SANDBOX_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx

# Required: Anthropic API key (for the Claude agent loop)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com
