# Required: FC Sandbox API key
FC_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx

# Required: Anthropic API key (for the Claude agent loop)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# FC_BASE_URL (required) — your fc-spawn control-plane URL.
FC_BASE_URL=https://fc-spawn.example.com
