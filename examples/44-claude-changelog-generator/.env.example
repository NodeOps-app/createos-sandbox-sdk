# FC Sandbox control-plane (required)
FCSPAWN_URL=https://createos-sandbox.example.com
CREATEOS_SANDBOX_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic proxy triple — forwarded into the sandbox as ANTHROPIC_* env vars.
# Use a real Anthropic key OR a proxy (ANTHROPIC_AUTH_TOKEN + ANTHROPIC_BASE_URL).
ANTHROPIC_AUTH_TOKEN=sk-ant-...
ANTHROPIC_BASE_URL=https://your-proxy/anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
