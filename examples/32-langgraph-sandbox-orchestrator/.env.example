# createos-sandbox control plane
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com
CREATEOS_SANDBOX_API_KEY=your-createos-sandbox-api-key

# OpenAI — required for the LangGraph agent LLM calls
OPENAI_API_KEY=sk_your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Optional: point at an OpenAI-compatible endpoint instead
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# OPENAI_API_URL=https://your-openai-compatible-endpoint/v1
