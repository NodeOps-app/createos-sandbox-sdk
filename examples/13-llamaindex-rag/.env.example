FC_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx
# FC_BASE_URL (required) — your fc-spawn control-plane URL.
FC_BASE_URL=https://fc-spawn.example.com

# OpenAI-compatible LLM endpoint. Any provider works; the SDK passes these
# straight through to llama-index's OpenAILike client inside the sandbox.
OPENAI_API_KEY=sk-...
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
