CREATEOS_SANDBOX_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx
# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com

# Firecrawl — used to scrape the live listings page. When unset, the example
# falls back to the bundled sample-listings.json and still runs the full FC
# sandbox / Claude / chart path.
FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_API_URL defaults to https://api.firecrawl.dev — set only to override.
# SCRAPE_URL defaults to an Airbnb search page — set to scrape a different page.

# Anthropic — Claude writes the extraction + pandas/matplotlib analysis code.
# The SDK reads ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN from the environment.
ANTHROPIC_AUTH_TOKEN=sk-...
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
