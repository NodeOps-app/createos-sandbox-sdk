# FC control plane (standard fc-sandbox-sdk inputs).
# In this repo the example dirs symlink .env -> ../.env, which already sets these.
FC_BASE_URL=https://fc-spawn.bhautik.in
FC_API_KEY=your-fc-api-key

# Managed Agents credentials live in a SEPARATE file: .env.ant (gitignored).
# Keeping them out of .env avoids the shared .env's internal Anthropic gateway
# vars (ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN) misrouting the real API calls.
#
#   .env.ant
#   ANTHROPIC_API_KEY=sk-ant-...               # org key with Managed Agents beta
#   ANTHROPIC_ENVIRONMENT_ID=env_...           # a self_hosted environment
#   ANTHROPIC_ENVIRONMENT_KEY=sk-ant-oat01-... # Console > Environments > Generate environment key
