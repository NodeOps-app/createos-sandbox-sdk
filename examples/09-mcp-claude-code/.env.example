# Required: createos-sandbox API key
CREATEOS_SANDBOX_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx

# Required: Anthropic auth — use either:
#   (a) Real Anthropic key:
ANTHROPIC_API_KEY=sk-ant-...
#   (b) Custom proxy (token + base URL):
# ANTHROPIC_AUTH_TOKEN=sk-...
# ANTHROPIC_BASE_URL=https://your-proxy/anthropic

# Optional: override the model used inside the sandbox (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com
