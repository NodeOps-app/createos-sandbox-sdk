# Required: FC Sandbox API key
FC_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx

# Required: Anthropic auth — use either:
#   (a) Real Anthropic key:
ANTHROPIC_API_KEY=sk-ant-...
#   (b) Custom proxy (token + base URL):
# ANTHROPIC_AUTH_TOKEN=sk-...
# ANTHROPIC_BASE_URL=https://your-proxy/anthropic

# Optional: override the model used inside the sandbox (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# FC_BASE_URL (required) — your fc-spawn control-plane URL.
FC_BASE_URL=https://fc-spawn.example.com
