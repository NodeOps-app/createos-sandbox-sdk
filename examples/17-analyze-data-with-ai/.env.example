CREATEOS_SANDBOX_API_KEY=fc_xxxxxxxxxxxxxxxxxxxxxxxx
# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com

# Anthropic-compatible endpoint. Claude generates the analysis code from the
# CSV schema. The example passes these straight to the @anthropic-ai/sdk
# client (baseURL + Bearer authToken).
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5
