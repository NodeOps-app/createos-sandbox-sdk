# CREATEOS_SANDBOX_BASE_URL (required) — your createos-sandbox control-plane URL.
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com
CREATEOS_SANDBOX_API_KEY=your-fc-api-key

# Anthropic / proxy (required for Claude agent calls).
# ANTHROPIC_BASE_URL overrides the default api.anthropic.com endpoint — set
# to a compatible proxy URL when using a DeepSeek-backed gateway.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=your-anthropic-auth-token
ANTHROPIC_MODEL=claude-sonnet-4-6
