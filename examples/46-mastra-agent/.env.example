# FC control-plane connection
CREATEOS_SANDBOX_BASE_URL=https://createos-sandbox.example.com
CREATEOS_SANDBOX_API_KEY=your-fc-api-key

# OpenAI-compatible provider (required by the Mastra agent inside the sandbox)
# OPENAI_API_URL is the provider base URL, e.g. https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
