{
  "name": "@computesdk/createos-sandbox",
  "version": "0.1.0",
  "description": "CreateOS provider for ComputeSDK — NodeOps Firecracker microVM sandboxes with pause/resume/fork snapshots",
  "keywords": [
    "code-execution",
    "computesdk",
    "createos",
    "createos-sandbox",
    "firecracker",
    "microvm",
    "nodeops",
    "provider",
    "sandbox",
    "snapshot"
  ],
  "homepage": "https://www.computesdk.com",
  "bugs": {
    "url": "https://github.com/computesdk/computesdk/issues"
  },
  "license": "MIT",
  "author": "NodeOps Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/computesdk/computesdk.git",
    "directory": "packages/createos-sandbox"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@computesdk/provider": "^2.1.3",
    "createos-sandbox-sdk": "file:../.."
  },
  "devDependencies": {
    "@computesdk/test-utils": "^2.0.0",
    "@types/node": "^20.19.39",
    "computesdk": "^4.1.3",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
