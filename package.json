{
  "name": "fc-sandbox-sdk",
  "version": "0.2.1",
  "description": "TypeScript SDK for the fc-spawn microVM sandbox control plane.",
  "keywords": [
    "compute",
    "fc-spawn",
    "firecracker",
    "microvm",
    "sandbox",
    "sdk"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt . '!**/*.md'",
    "fmt:check": "oxfmt --check . '!**/*.md'",
    "test": "bun run build && node --test tests/*.test.mjs",
    "docs:api": "typedoc --entryPoints src/index.ts --out docs/reference --githubPages false --hideGenerator",
    "pack:dry": "npm pack --dry-run",
    "publish:check": "npm whoami && bun run pack:dry",
    "prepublishOnly": "bun run test && bun run typecheck",
    "publish:dry": "bun run publish:check && npm publish --dry-run",
    "publish:npm": "bun run publish:check && npm publish"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typedoc": "0.28.19",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
